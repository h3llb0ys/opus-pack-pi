{
  "_comment": "Reference. install.sh merges ONLY hooks, opus-pack, packages — never overwrites unrelated keys. MCP servers live in mcp.json.example (read by pi-mcp-adapter).",

  "hooks": {
    "_comment": "1:1 Claude Code format. cc-bridge.hooks reads this block (or drop *.md into ~/.pi/agent/hooks/). You can copy entries from ~/.claude/settings.json.",
    "PreToolUse": [],
    "PostToolUse": [],
    "SessionStart": [],
    "Stop": []
  },

  "opus-pack": {
    "_comment": "opus-pack-pi extension flags.",
    "iterationGuard": {
      "_comment": "Cap on agent turns per run. /continue extends by extendBy.",
      "defaultCap": 40,
      "extendBy": 20
    },
    "safe-deny": {
      "enabled": true
    },
    "permissions": {
      "_comment": "Granular allow/confirm/deny rules. First match wins. Augments safe-deny. rules start empty — jq deep-merge on update would overwrite (arrays replace, not append) so defaults live here as _example_rules for copy-paste.",
      "default": "allow",
      "smart": true,
      "interactive": true,
      "_interactive_comment": "interactive=true → 4-way prompt (allow once/session/always/deny). 'allow always' persists into settings.local.json.",
      "rules": [],
      "_example_rules": [
        { "tool": "bash", "pattern": "sudo *", "action": "confirm" },
        { "tool": "edit", "path": ".github/**", "action": "confirm" },
        { "tool": "write", "path": "*.env", "action": "deny" }
      ]
    },
    "modelRouter": {
      "_comment": "Auto-switch model and thinking level per prompt. Provider-agnostic — fill `levels` with your provider+model ids. Disabled by default.",
      "enabled": false,
      "default": "medium",
      "autoBumpAfterTurns": 0,
      "_levels_example_anthropic": {
        "trivial": { "provider": "anthropic", "model": "claude-haiku-4-5",  "thinking": "minimal" },
        "medium":  { "provider": "anthropic", "model": "claude-sonnet-4-6", "thinking": "medium"  },
        "high":    { "provider": "anthropic", "model": "claude-opus-4-7",   "thinking": "high"    },
        "xhigh":   { "provider": "anthropic", "model": "claude-opus-4-7",   "thinking": "xhigh"   }
      },
      "_levels_example_openai": {
        "trivial": { "provider": "openai", "model": "gpt-5.3-mini", "thinking": "minimal" },
        "medium":  { "provider": "openai", "model": "gpt-5.3",      "thinking": "medium"  },
        "high":    { "provider": "openai", "model": "gpt-5.3",      "thinking": "high"    },
        "xhigh":   { "provider": "openai", "model": "gpt-5.3",      "thinking": "xhigh"   }
      },
      "_levels_example_ollama": {
        "trivial": { "provider": "ollama", "model": "qwen3-8b-instruct",     "thinking": "off" },
        "medium":  { "provider": "ollama", "model": "qwen3-30b-instruct",    "thinking": "off" },
        "high":    { "provider": "ollama", "model": "llama3.1-70b-instruct", "thinking": "off" },
        "xhigh":   { "provider": "ollama", "model": "llama3.1-70b-instruct", "thinking": "off" }
      },
      "levels": {},
      "rules": [],
      "_example_rules": [
        { "match": "\\b(typo|rename|formatting)\\b",                     "level": "trivial" },
        { "match": "\\b(refactor|architecture|design|migration)\\b",     "level": "high"    },
        { "match": "\\b(debug|investigate|root.?cause|flaky)\\b",        "level": "xhigh"   },
        { "minChars": 2000,                                              "level": "high"    }
      ]
    },
    "bashProgress": {
      "_comment": "Live widget for long bash commands.",
      "enabled": true,
      "minDurationMs": 2000,
      "tailLines": 5
    },
    "claudeMdLoader": {
      "_comment": "Auto-load CLAUDE.md / AGENTS.md from ~/.{claude,codex,gemini,pi} + cwd upward walk.",
      "enabled": true,
      "includeGlobal": true,
      "includeWalk": true,
      "maxTotalChars": 20000
    },
    "mcpCompress": {
      "_comment": "Collapse verbose MCP tool results to a single line per call.",
      "enabled": true,
      "prefixes": ["mcp_", "mcp__", "server_"],
      "maxLineLen": 160,
      "whitelist": []
    },
    "_extensions_comment": "Per-extension on/off lives in ~/.pi/agent/settings.local.json under opus-pack.extensions.disabled — managed via /opus-pack.",
    "piSearch": {
      "_comment": "Community extension discovery via GitHub topic:pi-package.",
      "enabled": true,
      "minStars": 0,
      "cacheTtlMs": 3600000,
      "denyList": []
    },
    "desktopNotify": {
      "_comment": "OS notification on agent completion.",
      "enabled": true,
      "minDuration": 10,
      "sound": true
    },
    "selfRecheck": {
      "_comment": "Auto-injects a self-critique follow-up for weak models. Two-stage by default: stage 1 lists defects, stage 2 emits a minimal patch — each as its own assistant message. Fires on agent_end when the active model id matches one of `models` (glob). Use /recheck status|on|off|now|skip. /recheck now bypasses all gates. In plan mode the 'what next?' dialog is deferred until recheck completes.",
      "enabled": false,
      "models": ["glm-*", "*qwen*", "deepseek*"],
      "minAssistantChars": 200,
      "maxPerSession": 0,
      "twoStage": true,
      "classifier": false,
      "_classifier_comment": "When true, before firing self-recheck, ask the currently active model a single YES/NO question ('Should this answer get a second pass?') and skip on NO. Cached by answer hash per session. Failures/timeouts fall back to firing so a broken classifier can't silently disable self-recheck. Adds one short API round-trip per otherwise-fireable turn — off by default.",
      "adaptiveTrigger": {
        "_comment": "Heuristic gate — skip cheap/trivial turns without an LLM call. Disabled by default (fires on every long turn that matches `models`). Turn on to cut recheck spam on Q&A, acks, and exploration turns.",
        "enabled": false,
        "requireStructureScore": 2,
        "requireToolUseOrCode": true,
        "cooldownUserTurns": 2,
        "skipIfAckOnly": "^\\s*(да|нет|ок|окей|понял(а)?|спасибо|норм|yes|no|ok|okay|thanks|thx|got it)[.!?]*\\s*$",
        "skipIfFactualAsk": "^\\s*(что|какой|какая|какое|какие|покажи|выведи|what|which|show|list|when|where)\\b"
      },
      "_prompt_comment": "Leave `prompt` empty for the two-stage flow. Stage 1 asks for at most 7 real defects (one-line `<where>: <wrong> → <should be>`); stage 2 emits a minimal patch, not a rewritten answer. Override `defectsPrompt` / `correctedPrompt` (strings) to tune each stage, or set a non-empty `prompt` to fall back to the legacy single-stage behavior (defects + full corrected answer in one message)."
    },
    "_compactHints_comment": "Fill compactHints with project-specific topics to preserve during /compact.",
    "compactHints": [],
    "_compactHints_example": [
      "Current file being edited and its recent changes",
      "Test results and error messages",
      "Architecture decisions made in this session"
    ]
  },

  "packages": [
    {
      "source": "git:github.com/obra/superpowers",
      "_comment": "Only skills/ is loaded. CC-only commands/agents/hooks are dropped (format incompatible with pi).",
      "skills": ["skills/*/SKILL.md"],
      "extensions": [],
      "prompts": []
    }
  ]
}
