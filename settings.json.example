{
  "_comment": "Эталон. install.sh мерджит ТОЛЬКО mcpServers, hooks, opus-pack, packages — не перезаписывает чужие ключи.",

  "mcpServers": {
    "ctm": {
      "_comment": "claude-total-memory через pi-mcp-adapter. Lazy = подсоединяется при первом вызове, idleTimeout убивает после 60с простоя. Запускаем модуль напрямую через python -m, без entry-point бинаря.",
      "command": "/Users/smirnov_as/extra/mcp/claude-total-memory/.venv/bin/python",
      "args": ["-m", "claude_total_memory.server"],
      "env": {},
      "cwd": "/Users/smirnov_as/extra/mcp/claude-total-memory",
      "lifecycle": "lazy",
      "idleTimeout": 60,
      "toolPrefix": "server"
    }
  },

  "hooks": {
    "_comment": "Формат 1:1 с Claude Code. Hook-bridge.ts читает этот блок. Можно копипастить из ~/.claude/settings.json.",
    "PreToolUse": [],
    "PostToolUse": [],
    "SessionStart": [],
    "Stop": []
  },

  "opus-pack": {
    "_comment": "Флаги opus-pack-pi extensions.",
    "max-turns": 40,
    "safe-deny": {
      "enabled": true
    },
    "permissions": {
      "_comment": "Granular allow/confirm/deny rules. First match wins. Augments safe-deny (hardcoded net).",
      "default": "allow",
      "rules": [
        { "tool": "bash", "pattern": "sudo *", "action": "confirm" },
        { "tool": "edit", "path": ".github/**", "action": "confirm" },
        { "tool": "write", "path": "*.env", "action": "deny" }
      ]
    },
    "desktopNotify": {
      "_comment": "OS notification on agent completion.",
      "enabled": true,
      "minDuration": 10,
      "sound": true
    },
    "compactHints": [
      "_comment: list of topics to preserve during compaction",
      "Current file being edited and its recent changes",
      "Test results and error messages",
      "Architecture decisions made in this session"
    ]
  },

  "packages": [
    {
      "source": "git:github.com/obra/superpowers",
      "_comment": "Только skills/. Отбрасываем CC-only commands/agents/hooks (формат не совместим с pi).",
      "skills": ["skills/*/SKILL.md"],
      "extensions": [],
      "prompts": []
    }
  ]
}
