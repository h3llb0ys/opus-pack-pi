{
  "_comment": "pi-mcp-adapter читает этот файл по пути ~/.pi/agent/mcp.json. install.sh мерджит ТОЛЬКО ключ mcpServers — settings и пользовательские сервера сохраняются.",

  "settings": {
    "toolPrefix": "server",
    "idleTimeout": 10
  },

  "mcpServers": {
    "ctm": {
      "_comment": "claude-total-memory. Реальный сервер живёт в src/server.py (не entry-point). lazy = подключается при первом mcp tool call, idleTimeout убивает после простоя.",
      "command": "/Users/smirnov_as/extra/mcp/claude-total-memory/.venv/bin/python",
      "args": ["/Users/smirnov_as/extra/mcp/claude-total-memory/src/server.py"],
      "env": {},
      "cwd": "/Users/smirnov_as/extra/mcp/claude-total-memory",
      "lifecycle": "lazy",
      "idleTimeout": 10
    }
  }
}
